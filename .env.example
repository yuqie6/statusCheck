# FastAPI
HOST=0.0.0.0
PORT=38481
APP_ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:38482,http://localhost:38482
ADMIN_TOKEN=

# Docker Compose
STATUSCHECK_PORT=38481
STATUSCHECK_ENV_FILE=.env
DOCKER_SUB2API_BASE_URL=http://host.docker.internal:18081

# Sub2API admin (required)
SUB2API_BASE_URL=http://127.0.0.1:18081
SUB2API_ADMIN_API_KEY=
SUB2API_TIMEOUT_SECONDS=20
SUB2API_GROUP_IDS=
SUB2API_INCLUDE_EXCLUSIVE_GROUPS=false

# Cache / scan
DASHBOARD_CACHE_TTL_SECONDS=60
ACCOUNT_SCAN_ENABLED=false
ACCOUNT_SCAN_TTL_SECONDS=180
ACCOUNT_SCAN_PAGE_SIZE=100
ACCOUNT_SCAN_MAX_PAGES=0

# Optional public-model probe (recommended if you want real model availability checks)
SUB2API_MONITOR_API_KEY=
SUB2API_MONITOR_GROUP_API_KEYS=
SUB2API_MONITOR_MODELS=gpt-5.4,gpt-5.4-mini,claude-sonnet-4-6,google/gemini-3-flash-preview
SUB2API_MONITOR_MODEL_SOURCES=groups,configured
SUB2API_MONITOR_USAGE_MODEL_LIMIT=10
SUB2API_MONITOR_TIMEOUT_SECONDS=18
SUB2API_MONITOR_MAX_TOKENS=8
SUB2API_MONITOR_TEMPERATURE=0
SUB2API_MONITOR_PROMPT=Reply with OK only.
SUB2API_MONITOR_CONCURRENCY=3
SUB2API_MONITOR_PROBE_ENDPOINT=chat_completions
